<resources>
    <string name="app_name">离线会议转写</string>
    <string name="app_subtitle">本地运行、优先离线、适合中文会议记录，也能兼容少量英文单词。</string>
    <string name="label_status">当前状态</string>
    <string name="label_transcript">转写结果</string>
    <string name="label_notes">使用说明</string>
    <string name="action_start">开始转写</string>
    <string name="action_stop">停止转写</string>
    <string name="action_clear">清空文本</string>
    <string name="action_copy">复制文本</string>
    <string name="action_save">保存到本机</string>
    <string name="option_continuous">会议连续模式：每段结束后自动继续监听</string>
    <string name="option_mixed_language">中英夹杂模式：尽量保留少量英文词</string>
    <string name="transcript_hint">建议把手机放在会议桌中央，离发言人 0.5 到 2 米，安静环境下识别更稳。</string>
    <string name="transcript_placeholder">转写内容会显示在这里。点击“开始转写”后，系统会请求麦克风权限。</string>
    <string name="partial_prefix">正在识别： </string>
    <string name="notes_body">1. 本版本是纯本地 APK，不依赖云端上传。\n2. 当前识别依赖 Android 设备上的离线语音识别能力；若系统未安装中文离线语音包，效果会受影响。\n3. 你这类 8 Gen 2 / 8 Elite 设备非常适合后续升级到更强的 Whisper 本地引擎，到时长会议和文件转写会更稳。\n4. 点击“保存到本机”后，文本会存到 App 私有文档目录，路径会在提示里显示。</string>

